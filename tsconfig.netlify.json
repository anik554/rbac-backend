{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist",
    "skipLibCheck": true,
    "declaration": false      // ← prevents .d.ts generation in netlify/functions
  },
  "include": ["src/**/*", "netlify/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.spec.ts",
    "**/*.e2e-spec.ts"
  ]
}